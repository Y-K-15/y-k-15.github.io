--- 
import TagPill from './TagPill.astro';
import type { Project } from '../site.config';

interface Props {
  project: Project;
  modalId?: string;
}

const { project, modalId } = Astro.props;
const Component = modalId ? 'button' : 'div';
const extraProps = modalId ? { 'data-modal-trigger': modalId, type: 'button' as const } : {};
---

<Component 
  {...extraProps}
  class={`group relative block w-full text-left p-5 h-full bg-white dark:bg-gray-950 border border-gray-200 dark:border-green-900/50 rounded-lg hover:border-gray-300 dark:hover:border-green-500 hover:shadow-sm dark:hover:shadow-[0_0_15px_rgba(34,197,94,0.1)] transition-all duration-300 ${modalId ? 'cursor-pointer' : ''}`}>
  <div class="flex flex-col h-full">
    <div class="flex justify-between items-start mb-2">
      <h3 class="text-lg font-bold text-gray-900 dark:text-green-500 group-hover:text-blue-600 dark:group-hover:text-green-400 transition-colors">
        {project.title}
      </h3>
      {project.isPrivate ? (
        <span class="text-xs font-medium text-gray-500 bg-gray-100 dark:bg-gray-900 dark:text-gray-400 px-2 py-1 rounded transition-colors">Private</span>
      ) : project.link && !modalId && (
        <a href={project.link} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-600 dark:text-green-900 dark:hover:text-green-500 z-20 transition-colors" aria-label={`Link to ${project.title}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      )}
    </div>
    
    {project.authors && (
      <div class="text-xs text-gray-500 dark:text-green-900 mb-2 italic transition-colors">
        {project.authors}
      </div>
    )}
    
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-4 flex-grow transition-colors">
      {project.description}
    </p>

    <div class="mt-auto">
      <div class="flex flex-wrap gap-2">
        {project.tags.map((tag) => (
          <TagPill text={tag} />
        ))}
      </div>
    </div>
  </div>
  
  {!project.isPrivate && project.link && !modalId && (
    <a href={project.link} target="_blank" rel="noopener noreferrer" class="absolute inset-0 z-10" aria-label={`View ${project.title}`}>
      <span class="sr-only">View {project.title}</span>
    </a>
  )}
</Component>
