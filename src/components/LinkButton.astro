---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary';
  target?: string;
  rel?: string;
  class?: string;
}

const { href, variant = 'secondary', target, rel, class: className } = Astro.props;

const baseStyles = "inline-flex items-center justify-center px-4 py-2 rounded-md text-sm font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500";
const variants = {
  primary: "bg-primary text-white hover:bg-gray-800 dark:bg-green-600 dark:hover:bg-green-700 dark:text-black",
  secondary: "bg-white text-gray-700 border border-gray-300 hover:bg-gray-50 dark:bg-gray-900 dark:text-green-400 dark:border-green-900/50 dark:hover:bg-gray-800"
};
---

<a 
  href={href} 
  target={target} 
  rel={rel} 
  class:list={[baseStyles, variants[variant], className]}
>
  <slot />
</a>
