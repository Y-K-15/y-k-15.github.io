---
import type { Project } from '../site.config';
import LinkButton from './LinkButton.astro';
import TagPill from './TagPill.astro';

interface Props {
  id: string;
  project: Project;
}

const { id, project } = Astro.props;
---

<div id={id} class="modal fixed inset-0 z-50 hidden" aria-hidden="true">
  {/* Backdrop */}
  <div class="modal-backdrop absolute inset-0 bg-black/50 transition-opacity"></div>

  {/* Modal Content */}
  <div class="modal-content absolute inset-0 flex items-center justify-center p-4">
    <div class="bg-white dark:bg-gray-900 rounded-lg shadow-xl max-w-2xl w-full max-h-[90vh] overflow-y-auto relative animate-fade-in-up transition-colors duration-300">
      
      {/* Close Button */}
      <button class="modal-close absolute top-4 right-4 text-gray-400 hover:text-gray-600 dark:hover:text-green-500 focus:outline-none transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="p-8">
        <h2 class="text-2xl font-bold mb-2 dark:text-green-500">{project.title}</h2>
        {project.authors && (
          <p class="text-sm text-gray-500 dark:text-green-900 italic mb-4">{project.authors}</p>
        )}
        
        <div class="flex flex-wrap gap-2 mb-6">
          {project.tags.map((tag) => (
            <TagPill text={tag} />
          ))}
        </div>

        <div class="prose prose-sm max-w-none text-gray-700 dark:text-gray-300 mb-8">
          <p class="whitespace-pre-line">{project.longDescription || project.description}</p>
        </div>

        {/* Related Presentations */}
        {project.relatedPresentations && project.relatedPresentations.length > 0 && (
          <div class="mb-6">
            <h3 class="text-lg font-bold mb-3 border-b dark:border-gray-800 pb-1 dark:text-green-600">Related Presentations</h3>
            <ul class="space-y-3">
              {project.relatedPresentations.map(pres => (
                <li class="text-sm">
                  <div class="font-medium dark:text-gray-200">{pres.title}</div>
                  <div class="text-gray-600 dark:text-gray-400">
                    {pres.event} 
                    {pres.location && <span> @ {pres.location}</span>}
                    <span class="text-gray-400 mx-2">|</span> 
                    {pres.date}
                  </div>
                </li>
              ))}
            </ul>
          </div>
        )}

        {/* Related Papers */}
        {project.relatedPapers && project.relatedPapers.length > 0 && (
          <div class="mb-6">
            <h3 class="text-lg font-bold mb-3 border-b dark:border-gray-800 pb-1 dark:text-green-600">Publications / Papers</h3>
            <ul class="space-y-2">
              {project.relatedPapers.map(paper => (
                <li>
                  <a href={paper.link} target="_blank" rel="noopener noreferrer" class="text-blue-600 dark:text-green-500 hover:underline flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    {paper.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {/* Links */}
        {project.link && (
          <div class="mt-8 pt-4 border-t dark:border-gray-800 flex justify-end">
            <LinkButton href={project.link} target="_blank" rel="noopener noreferrer" class="dark:bg-green-900 dark:border-green-500 dark:text-green-400">
              Visit Project / Repository
            </LinkButton>
          </div>
        )}
      </div>
    </div>
  </div>
</div>
