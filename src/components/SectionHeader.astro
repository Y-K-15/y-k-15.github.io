---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<h2 class="text-xl font-bold mb-6 mt-12 flex items-center dark:text-green-500 transition-colors duration-300">
  {title}
  <span class="ml-3 h-px flex-1 bg-gray-200 dark:bg-green-900/50 transition-colors duration-300"></span>
</h2>
